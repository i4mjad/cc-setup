        "name": "firebase",
        "kind": "skills-cli",
        "ref": "firebase/agent-skills",
        "invoke": "/firebase-basics, /firebase-auth-basics, /firebase-firestore, /firebase-security-rules-auditor"
      }
    ]
  },
